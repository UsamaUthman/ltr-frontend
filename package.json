{
  "name": "ltr-alpha-frontend",
  "appName": "LTR Trade",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "generate:metadata": "node scripts/generate-app-metadata.mjs",
    "version:patch": "node scripts/update-app-metadata.mjs patch",
    "version:minor": "node scripts/update-app-metadata.mjs minor",
    "version:major": "node scripts/update-app-metadata.mjs major",
    "predev": "npm run generate:metadata",
    "dev": "vite",
    "prebuild": "npm run generate:metadata",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.18.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.3"
  }
